<Window x:Class="VmManager.App.TurnOffConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turn off virtual machine"
        Icon="Assets/AppIcon.ico"
        Width="420" Height="190"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                       FontSize="30" Foreground="#D98200" VerticalAlignment="Top" />
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="PromptTextBlock"
                           Text="Turn off this virtual machine?"
                           FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="MessageTextBlock" Margin="0,10,0,0"
                           TextWrapping="Wrap" Foreground="#555555" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="30" IsCancel="True" />
            <Button Content="Turn off" Width="90" Height="30" Margin="8,0,0,0"
                    IsDefault="True" Click="TurnOffButton_Click" />
        </StackPanel>
    </Grid>
</Window>
