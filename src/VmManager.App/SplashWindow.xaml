<Window x:Class="VmManager.App.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VM Manager is starting"
        Width="440" Height="230"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="10" BorderBrush="#D6DADE" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.28" />
        </Border.Effect>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <Image Source="Assets/AppIcon.png" Width="58" Height="58" Margin="0,0,16,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VM Manager" FontSize="28" FontWeight="SemiBold" Foreground="#202428" />
                    <TextBlock Text="Local Hyper-V management" Margin="0,4,0,0"
                               FontSize="13" Foreground="#687078" />
                </StackPanel>
            </StackPanel>

            <TextBlock x:Name="StatusTextBlock" Grid.Row="2" Text="Starting..."
                       Margin="0,0,0,10" FontSize="13" Foreground="#40464C" />
            <ProgressBar Grid.Row="3" Height="5" IsIndeterminate="True"
                         Foreground="#2878D0" Background="#E5E9ED" />
        </Grid>
    </Border>
</Window>
