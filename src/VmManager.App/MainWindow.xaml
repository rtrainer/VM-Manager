<Window x:Class="VmManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VM Manager" Height="600" Width="980" MinHeight="450" MinWidth="760"
        Icon="Assets/AppIcon.ico"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Local Hyper-V Virtual Machines" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Manage VM state and organize machines into custom groups."
                           Foreground="#666666" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Width="36" Height="32" Margin="0,0,8,0"
                        ToolTip="Settings" Click="SettingsButton_Click">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>
                <Button Content="Refresh" Width="90" Height="32"
                        HorizontalAlignment="Right" Click="RefreshButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Show:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="GroupFilterComboBox" Grid.Column="1" Height="32"
                      Padding="8,0" VerticalContentAlignment="Center"
                      DisplayMemberPath="Name" SelectionChanged="GroupFilterComboBox_SelectionChanged" />
            <Button Grid.Column="2" Content="New group" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    Click="NewGroupButton_Click" />
            <Button x:Name="DeleteGroupButton" Grid.Column="3" Content="Delete group" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    IsEnabled="False" Click="DeleteGroupButton_Click" />
            <Button x:Name="StartGroupButton" Grid.Column="5" Content="Start group" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    IsEnabled="False" Click="StartGroupButton_Click" />
            <Button x:Name="ShutDownGroupButton" Grid.Column="6" Content="Shut down group" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    IsEnabled="False" Click="ShutDownGroupButton_Click" />
        </Grid>

        <DataGrid x:Name="VmGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" SelectionChanged="VmGrid_SelectionChanged"
                  PreviewMouseRightButtonDown="VmGrid_PreviewMouseRightButtonDown">
            <DataGrid.RowStyle>
                <Style TargetType="{x:Type DataGridRow}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Background" Value="#E8F5E9" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.ContextMenu>
                <ContextMenu Placement="MousePoint" Opened="VmContextMenu_Opened">
                    <MenuItem x:Name="ContextStartVmMenuItem" Header="Start"
                              Click="ContextStartVmMenuItem_Click" />
                    <MenuItem x:Name="ContextShutDownVmMenuItem" Header="Shut down"
                              Click="ContextShutDownVmMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextTurnOffVmMenuItem" Header="Turn off..."
                              Click="ContextTurnOffVmMenuItem_Click" />
                    <Separator />
                    <MenuItem x:Name="ContextAddToGroupMenuItem" Header="Add to group" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" />
                <DataGridTextColumn Header="CPU" Binding="{Binding CpuDisplay}" Width="80" />
                <DataGridTextColumn Header="Memory" Binding="{Binding MemoryDisplay}" Width="110" />
                <DataGridTextColumn Header="Groups" Binding="{Binding GroupsDisplay}" Width="220" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="StartVmButton" Grid.Column="0" Content="Start" Width="90" Height="32"
                    IsEnabled="False" Click="StartVmButton_Click" />
            <Button x:Name="ShutDownVmButton" Grid.Column="1" Content="Shut down" Width="100" Height="32"
                    Margin="8,0,0,0" IsEnabled="False" Click="ShutDownVmButton_Click" />
            <Button x:Name="TurnOffVmButton" Grid.Column="2" Content="Turn off..." Width="90" Height="32"
                    Margin="8,0,0,0" IsEnabled="False" Click="TurnOffVmButton_Click" />
            <TextBlock Grid.Column="4" Text="Group:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="MembershipGroupComboBox" Grid.Column="5" Height="32"
                      Padding="8,0" VerticalContentAlignment="Center" DisplayMemberPath="Name"
                      SelectionChanged="MembershipGroupComboBox_SelectionChanged" />
            <Button x:Name="AddToGroupButton" Grid.Column="6" Content="Add" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    IsEnabled="False" Click="AddToGroupButton_Click" />
            <Button x:Name="RemoveFromGroupButton" Grid.Column="7" Content="Remove" Height="32" Margin="8,0,0,0" Padding="12,0"
                    VerticalContentAlignment="Center"
                    IsEnabled="False" Click="RemoveFromGroupButton_Click" />
        </Grid>

        <Border Grid.Row="4" Background="#F1F3F5" Padding="10,7">
            <TextBlock x:Name="StatusTextBlock" Text="Ready" TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
