<Window x:Class="VmManager.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VM Manager Settings"
        Icon="Assets/AppIcon.ico"
        Width="500" Height="270"
        MinWidth="460" MinHeight="250"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Background="#FAF8FC">
    <Window.Resources>
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="12" Background="#C8C5D2" />
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.25" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6868E8" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E8E4EC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="#303038" VerticalAlignment="Center" Margin="0,0,14,0" />
                <TextBlock Text="VM Manager Settings" FontSize="16" FontWeight="SemiBold"
                           Foreground="#24242B" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="14,16,14,14" Padding="0,0,0,14"
                BorderBrush="#E1DDE5" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets"
                           FontSize="18" Foreground="#777582" VerticalAlignment="Top" Margin="0,4,0,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Start Minimized" FontSize="14" Foreground="#24242B" />
                    <TextBlock Text="Open VM Manager in the system tray when it starts."
                               Margin="0,10,14,0" FontSize="13" Foreground="#777582"
                               TextWrapping="Wrap" />
                </StackPanel>
                <CheckBox x:Name="StartMinimizedToggle" Grid.Column="2"
                          Style="{StaticResource ToggleSwitchStyle}"
                          AutomationProperties.Name="Start minimized"
                          VerticalAlignment="Top" Margin="0,0,2,0"
                          Click="StartMinimizedToggle_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="VersionTextBlock" Grid.Row="2"
                   Margin="16,0,16,14" HorizontalAlignment="Right"
                   FontSize="12" Foreground="#777582" />
    </Grid>
</Window>
