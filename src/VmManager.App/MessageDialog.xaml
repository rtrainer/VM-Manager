<Window x:Class="VmManager.App.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="IconTextBlock" Grid.Column="0"
                       FontFamily="Segoe MDL2 Assets" FontSize="30"
                       VerticalAlignment="Top" />
            <TextBlock x:Name="MessageTextBlock" Grid.Column="1"
                       TextWrapping="Wrap" FontSize="14"
                       VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button x:Name="SecondaryButton" Width="90" Height="30" Margin="0,0,8,0"
                    Click="SecondaryButton_Click" />
            <Button x:Name="PrimaryButton" Width="90" Height="30"
                    IsDefault="True" Click="PrimaryButton_Click" />
        </StackPanel>
    </Grid>
</Window>
